# Ignore everything by default
*

# Except src (frontend source code)
!src/
!src/**

# Except projects/004-video-downloader
!projects/
!projects/004-video-downloader/
!projects/004-video-downloader/**

# Except root index.html
!index.html

# Except .gitignore itself
!.gitignore

# Ignore unnecessary files
**/.DS_Store
**/*.zip
**/README.md

# Ignore other projects
projects/001-growNewUsers/
projects/002-meetings/
projects/003-activation/
